# ---- Database (Neon Postgres) ----
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/clinic?sslmode=require

# ---- Backend API URL (used by the agent to call your FastAPI backend) ----
BACKEND_URL=http://localhost:8000

# ---- LiveKit (from cloud.livekit.io project settings) ----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---- STT ----
DEEPGRAM_API_KEY=

# ---- TTS ----
CARTESIA_API_KEY=
# or ELEVEN_API_KEY= if you swap the TTS plugin

# ---- LLM ----
OPENAI_API_KEY=
